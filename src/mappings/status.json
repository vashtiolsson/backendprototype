{
  "concept": "SupportType",
  "ontology_iri": "http://uva.thesis/ontologies/income#supportType",
  "description": "Maps source fields that describe benefit, grant, loan, or study-support categories to the SupportType concept. Each rule identifies the source value used to infer the ontology-level support type.",
  "version": "0.1.0-synthetic-aligned",
  "rules": [
    {
      "source_file": "af_benefit_type_decision.csv",
      "source_field": "benefit_type",
      "scope_field": "scope_pct",
      "transformation": "benefit_type_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "Activity support": "ActivitySupport"
      },
      "source_value_field": "benefit_type",
      "rationale": "AF benefit type decisions describe the type of support granted to the person. A value such as 'Activity support' maps to the ontology-level ActivitySupport support type."
    },
    {
      "source_file": "fk_case.csv",
      "source_field": "benefit_group_code",
      "transformation": "benefit_group_code_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "FK:AS": "ActivitySupport"
      },
      "source_value_field": "benefit_group_code",
      "rationale": "FK case records use benefit_group_code to classify the benefit group. The code FK:AS represents activity support and is therefore mapped to ActivitySupport."
    },
    {
      "source_file": "fk_period_benefit_decision.csv",
      "source_field": "benefit_type",
      "scope_field": "scope_pct",
      "transformation": "benefit_type_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "Activity support": "ActivitySupport"
      },
      "source_value_field": "benefit_type",
      "rationale": "FK period benefit decisions describe the decided benefit type and include the scope of the benefit. Activity support is mapped to the ontology-level ActivitySupport support type."
    },
    {
      "source_file": "fk_payment.csv",
      "source_field": "benefit_type",
      "transformation": "payment_benefit_type_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "Activity support": "ActivitySupport"
      },
      "source_value_field": "benefit_type",
      "rationale": "FK payment records include the benefit_type associated with the paid amount. Activity support payments are mapped to ActivitySupport."
    },
    {
      "source_file": "csn_study_support_case.csv",
      "source_field": "support_type",
      "description_field": "support_form_description",
      "transformation": "support_type_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "student_grant": "StudySupport"
      },
      "source_value_field": "support_type",
      "rationale": "CSN study support cases describe the type of study support connected to the person. The value student_grant indicates study-related financial support and maps to StudySupport."
    },
    {
      "source_file": "csn_study_support_case.csv",
      "source_field": "support_form_code",
      "description_field": "support_form_description",
      "transformation": "support_form_code_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "GRUND": "StudySupport"
      },
      "source_value_field": "support_form_code",
      "rationale": "The CSN support_form_code GRUND describes standard student finance for studies in Sweden and is therefore mapped to StudySupport."
    },
    {
      "source_file": "csn_approved_amounts.csv",
      "source_field": "amount_type_code",
      "description_field": "amount_type_label",
      "transformation": "amount_type_code_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "GRUNDB": "StudentGrant",
        "GRUNDL": "StudentLoan"
      },
      "source_value_field": "amount_type_code",
      "rationale": "CSN approved amounts are divided by amount type. GRUNDB represents the grant component and maps to StudentGrant, while GRUNDL represents the loan component and maps to StudentLoan."
    },
    {
      "source_file": "csn_grant_decision.csv",
      "source_field": "grant_code",
      "description_field": "decision_type",
      "scope_field": "scope_pct",
      "transformation": "grant_code_to_support_type",
      "target_class": "SupportType",
      "target_property": "supportType",
      "target_value_map": {
        "GRUNDB": "StudentGrant"
      },
      "source_value_field": "grant_code",
      "rationale": "The CSN grant decision identifies the grant component using grant_code. GRUNDB maps to StudentGrant."
    }
  ]
}