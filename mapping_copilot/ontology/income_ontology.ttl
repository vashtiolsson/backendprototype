:ActivitySupport rdf:type owl:NamedIndividual ,
                          :SupportType ;
                 rdfs:label "Activity Support"@en .


###  http://uva.thesis/ontologies/income#Approved
:Approved rdf:type owl:NamedIndividual ,
                   :Status ;
          rdfs:label "Approved"@en .


###  http://uva.thesis/ontologies/income#Employed
:Employed rdf:type owl:NamedIndividual ,
                   :Occupation ;
          rdfs:label "Employed"@en .


###  http://uva.thesis/ontologies/income#Inactive
:Inactive rdf:type owl:NamedIndividual ,
                   :Status ;
          rdfs:label "Inactive"@en .


###  http://uva.thesis/ontologies/income#Initiated
:Initiated rdf:type owl:NamedIndividual ,
                    :Status ;
           rdfs:label "Inititated"@en .


###  http://uva.thesis/ontologies/income#Jane
:Jane rdf:type owl:NamedIndividual ,
               :Person ;
      :hasIncome :Jane_AS ;
      rdfs:label "Jane Doe"@en .


###  http://uva.thesis/ontologies/income#Jane_AS
:Jane_AS rdf:type owl:NamedIndividual ,
                  :Income ;
         :amount :Jane_AS_Amount ;
         :occupation :JobSeeker ;
         :status :Inactive ;
         :supportType :ActivitySupport ;
         :timePeriod :Jane_AS_Period ;
         rdfs:label "Jane AS"@en .


###  http://uva.thesis/ontologies/income#Jane_AS_Amount
:Jane_AS_Amount rdf:type owl:NamedIndividual ,
                         :MonetaryAmount ;
                :frequency :Total ;
                :currency "SEK" ;
                :value 29120 .


###  http://uva.thesis/ontologies/income#Jane_AS_Period
:Jane_AS_Period rdf:type owl:NamedIndividual ,
                         :TimePeriod ;
                :endDate "2025-12-31" ;
                :startDate "2025-09-01" ;
                rdfs:label "Jane AS Period"@en .


###  http://uva.thesis/ontologies/income#JobSeeker
:JobSeeker rdf:type owl:NamedIndividual ,
                    :Occupation ;
           rdfs:label "Job Seeker"@en .


###  http://uva.thesis/ontologies/income#Month
:Month rdf:type owl:NamedIndividual ,
                :Frequency ;
       rdfs:label "Month"@en .


