:Student rdf:type owl:NamedIndividual ,
                  :Occupation ;
         rdfs:label "Student"@en .


###  http://uva.thesis/ontologies/income#StudyGrant
:StudyGrant rdf:type owl:NamedIndividual ,
                     :SupportType ;
            rdfs:label "StudyGrant"@en .


###  http://uva.thesis/ontologies/income#StudyLoan
:StudyLoan rdf:type owl:NamedIndividual ,
                    :SupportType ;
           rdfs:label "Study Loan"@en .


###  http://uva.thesis/ontologies/income#Total
:Total rdf:type owl:NamedIndividual ,
                :Frequency ;
       rdfs:label "Total"@en .


